IDENTIFICATION DIVISION.
PROGRAM-ID. CALCULATE-PREMIUM.
AUTHOR. HEALTHINSURE CORE TEAM.

ENVIRONMENT DIVISION.
DATA DIVISION.
WORKING-STORAGE SECTION.
01 WS-BASE-PREMIUM     PIC 9(10).
01 WS-AGE              PIC 9(3).
01 WS-BMI              PIC 9(3).
01 WS-CHRONIC          PIC X(1).
01 WS-SMOKER           PIC X(1).
01 WS-SCORE            PIC 9(2) VALUE 0.
01 WS-MULT-PCT         PIC 9(4).
01 WS-RISK-LEVEL       PIC X(10).
01 WS-BMI-CATEGORY     PIC X(15).
01 WS-MONTHLY          PIC 9(10).
01 WS-ANNUAL           PIC 9(10).
01 WS-MONTHLY-OUT      PIC Z(9)9.
01 WS-ANNUAL-OUT       PIC Z(9)9.
01 WS-OUTPUT           PIC X(250).

PROCEDURE DIVISION.
    DISPLAY 1 UPON ARGUMENT-NUMBER.
    ACCEPT WS-BASE-PREMIUM FROM ARGUMENT-VALUE.
    DISPLAY 2 UPON ARGUMENT-NUMBER.
    ACCEPT WS-AGE FROM ARGUMENT-VALUE.
    DISPLAY 3 UPON ARGUMENT-NUMBER.
    ACCEPT WS-BMI FROM ARGUMENT-VALUE.
    DISPLAY 4 UPON ARGUMENT-NUMBER.
    ACCEPT WS-CHRONIC FROM ARGUMENT-VALUE.
    DISPLAY 5 UPON ARGUMENT-NUMBER.
    ACCEPT WS-SMOKER FROM ARGUMENT-VALUE.

    IF WS-BMI > 30
        ADD 2 TO WS-SCORE
    ELSE
        IF WS-BMI > 25
            ADD 1 TO WS-SCORE
        END-IF
    END-IF.

    IF WS-AGE > 50
        ADD 2 TO WS-SCORE
    ELSE
        IF WS-AGE > 35
            ADD 1 TO WS-SCORE
        END-IF
    END-IF.

    IF WS-CHRONIC = "Y"
        ADD 3 TO WS-SCORE
    END-IF.

    EVALUATE TRUE
        WHEN WS-SCORE <= 1
            MOVE "Low" TO WS-RISK-LEVEL
            MOVE 100 TO WS-MULT-PCT
        WHEN WS-SCORE <= 3
            MOVE "Medium" TO WS-RISK-LEVEL
            MOVE 130 TO WS-MULT-PCT
        WHEN OTHER
            MOVE "High" TO WS-RISK-LEVEL
            MOVE 170 TO WS-MULT-PCT
    END-EVALUATE.

    IF WS-SMOKER = "Y"
        COMPUTE WS-MULT-PCT = WS-MULT-PCT * 120 / 100
    END-IF.

    COMPUTE WS-MONTHLY ROUNDED = WS-BASE-PREMIUM * WS-MULT-PCT / 100.
    COMPUTE WS-ANNUAL = (WS-MONTHLY * 12) - (WS-MONTHLY / 2).

    EVALUATE TRUE
        WHEN WS-BMI < 19
            MOVE "Underweight" TO WS-BMI-CATEGORY
        WHEN WS-BMI < 25
            MOVE "Normal" TO WS-BMI-CATEGORY
        WHEN WS-BMI < 30
            MOVE "Overweight" TO WS-BMI-CATEGORY
        WHEN OTHER
            MOVE "Obese" TO WS-BMI-CATEGORY
    END-EVALUATE.

    MOVE WS-MONTHLY TO WS-MONTHLY-OUT.
    MOVE WS-ANNUAL TO WS-ANNUAL-OUT.

    STRING '{"status": "OK", "riskLevel": "' FUNCTION TRIM(WS-RISK-LEVEL)
           '", "bmiCategory": "' FUNCTION TRIM(WS-BMI-CATEGORY)
           '", "monthlyPremium": ' FUNCTION TRIM(WS-MONTHLY-OUT)
           ', "annualPremium": ' FUNCTION TRIM(WS-ANNUAL-OUT)
           '}' DELIMITED BY SIZE INTO WS-OUTPUT.

    DISPLAY FUNCTION TRIM(WS-OUTPUT).
    GOBACK.
