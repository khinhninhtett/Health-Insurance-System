IDENTIFICATION DIVISION.
PROGRAM-ID. VALIDATE-MEDICAL-SUBMISSION.
AUTHOR. HEALTHINSURE CORE TEAM.

ENVIRONMENT DIVISION.
DATA DIVISION.
WORKING-STORAGE SECTION.
01 WS-AGE          PIC 9(3).
01 WS-BMI          PIC 9(3).
01 WS-HEART-RATE   PIC 9(3).
01 WS-BLOOD-GROUP  PIC X(5).
01 WS-PDF-PRESENT  PIC X(1).
01 WS-VALID        PIC X(1) VALUE "Y".
01 WS-REASON       PIC X(100) VALUE SPACES.
01 WS-OUTPUT       PIC X(250).

PROCEDURE DIVISION.
    DISPLAY 1 UPON ARGUMENT-NUMBER.
    ACCEPT WS-AGE FROM ARGUMENT-VALUE.
    DISPLAY 2 UPON ARGUMENT-NUMBER.
    ACCEPT WS-BMI FROM ARGUMENT-VALUE.
    DISPLAY 3 UPON ARGUMENT-NUMBER.
    ACCEPT WS-HEART-RATE FROM ARGUMENT-VALUE.
    DISPLAY 4 UPON ARGUMENT-NUMBER.
    ACCEPT WS-BLOOD-GROUP FROM ARGUMENT-VALUE.
    DISPLAY 5 UPON ARGUMENT-NUMBER.
    ACCEPT WS-PDF-PRESENT FROM ARGUMENT-VALUE.

    IF WS-AGE < 1 OR WS-AGE > 120
        MOVE "N" TO WS-VALID
        MOVE "Age value looks invalid." TO WS-REASON
    END-IF.

    IF WS-VALID = "Y" AND WS-PDF-PRESENT NOT = "Y"
        MOVE "N" TO WS-VALID
        MOVE "Medical record PDF is required." TO WS-REASON
    END-IF.

    IF WS-VALID = "Y" AND (WS-BMI < 10 OR WS-BMI > 70)
        MOVE "N" TO WS-VALID
        MOVE "BMI value looks invalid." TO WS-REASON
    END-IF.

    IF WS-VALID = "Y" AND (WS-HEART-RATE < 30 OR WS-HEART-RATE > 220)
        MOVE "N" TO WS-VALID
        MOVE "Heart rate value looks invalid." TO WS-REASON
    END-IF.

    IF WS-VALID = "Y"
        IF WS-BLOOD-GROUP = "A+" OR WS-BLOOD-GROUP = "A-" OR
           WS-BLOOD-GROUP = "B+" OR WS-BLOOD-GROUP = "B-" OR
           WS-BLOOD-GROUP = "AB+" OR WS-BLOOD-GROUP = "AB-" OR
           WS-BLOOD-GROUP = "O+" OR WS-BLOOD-GROUP = "O-"
            CONTINUE
        ELSE
            MOVE "N" TO WS-VALID
            MOVE "Blood group is invalid." TO WS-REASON
        END-IF
    END-IF.

    IF WS-VALID = "Y"
        STRING '{"status": "VALID", "message": "Submission looks complete."}'
            DELIMITED BY SIZE INTO WS-OUTPUT
    ELSE
        STRING '{"status": "INVALID", "message": "' FUNCTION TRIM(WS-REASON) '"}'
            DELIMITED BY SIZE INTO WS-OUTPUT
    END-IF.

    DISPLAY FUNCTION TRIM(WS-OUTPUT).
    GOBACK.
